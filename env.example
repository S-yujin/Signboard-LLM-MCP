# .env.example
# 이 파일을 복사해서 .env 로 이름 변경 후 실제 키를 입력하세요.
# cp .env.example .env

# ── 필수 ──────────────────────────────────────────────
# OpenAI API 키 (https://platform.openai.com/api-keys)
OPENAI_API_KEY= 


# ── 선택 (없으면 mock 데이터로 동작) ─────────────────
# 국세청 공공데이터 서비스키 (https://www.data.go.kr)
NTS_SERVICE_KEY=

# 사업자 검색 API (자체 DB 또는 외부 API)
BUSINESS_SEARCH_API_URL=
BUSINESS_SEARCH_API_KEY=

# ── 일반 설정 ─────────────────────────────────────────
LOG_LEVEL=INFO
OUTPUT_DIR=./outputs
