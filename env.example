# .env.example
# cp .env.example .env 후 실제 키를 입력하세요.

# ── 필수 ──────────────────────────────────────────────
# Google Gemini API 키 (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=

# ── Step 2: 비즈노 후보 검색 (선택, 없으면 mock) ─────
# 가입 및 API 키 발급: https://api.bizno.net/join
# 무료: 1일 200건, 상호명/사업자번호 검색
BIZNO_API_KEY=

# ── Step 3: 국세청 최종 상태 검증 (선택, 없으면 mock) ─
# 발급: https://www.data.go.kr → '사업자등록정보 진위확인 및 상태조회'
NTS_SERVICE_KEY=

# ── 일반 설정 ─────────────────────────────────────────
LOG_LEVEL=INFO
OUTPUT_DIR=./outputs
