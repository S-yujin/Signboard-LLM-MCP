# ──────────────────────────────────────────────────────────────────────────────
# .env.example
# 이 파일을 복사하여 .env 로 저장하고 실제 API 키를 입력하세요.
#   cp .env.example .env
# ──────────────────────────────────────────────────────────────────────────────

# ── Google Gemini ──────────────────────────────────────────────────────────────
# 발급: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── 카카오 로컬 API ────────────────────────────────────────────────────────────
# 발급 절차:
#   1. https://developers.kakao.com 접속 → 카카오 계정으로 로그인
#   2. 상단 [내 애플리케이션] → [애플리케이션 추가하기]
#   3. 앱 이름 입력 (예: signboard-llm) → 저장
#   4. 생성된 앱 선택 → [앱 키] 탭 → REST API 키 복사
#   5. [앱 설정] → [플랫폼] → [Web 플랫폼 등록] → http://localhost 추가 (필수)
#
# 무료 할당량: 일 300,000건 (역지오코딩 + 키워드 검색 합산)
# 용도:
#   - 역지오코딩  : GPS 좌표 → 행정구역 주소 (sido/sigungu/eupmyeondong)
#   - POI 검색   : GPS 반경 R미터 내 장소 키워드 검색 (Geospatial Filtering)
KAKAO_API_KEY=your_kakao_rest_api_key_here

# ── 비즈노 API ─────────────────────────────────────────────────────────────────
# 가입: https://api.bizno.net/join
# 무료: 1일 200건 / 상호명·사업자번호 검색 가능
BIZNO_API_KEY=your_bizno_api_key_here

# ── 국세청 공공데이터 API ──────────────────────────────────────────────────────
# 발급: https://www.data.go.kr → '사업자등록정보 진위확인 및 상태조회' 검색 → 활용신청
NTS_SERVICE_KEY=your_nts_service_key_here

# ── 선택 설정 ──────────────────────────────────────────────────────────────────
# 로그 레벨: DEBUG | INFO | WARNING | ERROR (기본: INFO)
LOG_LEVEL=INFO

# 결과 저장 디렉토리 (기본: ./outputs)
OUTPUT_DIR=./outputs

# POI 검색 반경 (미터, 기본: 300)
# 도심 밀집 상권이면 100~200, 일반 주택가면 300~500 권장
POI_SEARCH_RADIUS_M=300

# GPS 거리 감쇠 스케일 (미터, 기본: 100)
# S_gps = exp(-d / GPS_DECAY_SCALE_M)
# 100m 기준: d=100m → 0.37, d=200m → 0.14, d=500m → 0.007
GPS_DECAY_SCALE_M=100.0
